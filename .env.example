# Copy to .env
X_CLIENT_ID=YOUR_X_CLIENT_ID
DATABASE_URL=postgres://user:pass@db.xxx.supabase.co:5432/postgres?sslmode=require

# Token storage: "file" (default, works anywhere) or "keychain" (macOS only).
# In file mode, bootstrap with X_REFRESH_TOKEN or run scripts/oauth_setup.py.
# TOKEN_STORE=file
# REFRESH_TOKEN_FILE=.refresh_token
# X_REFRESH_TOKEN=                  # Optional: initial refresh token for file mode

# macOS Keychain (only used when TOKEN_STORE=keychain)
# KEYCHAIN_SERVICE=twitter-fetcher.refresh_token

# Optional overrides (defaults shown)
# POLL_INTERVAL_SECONDS=300
# MAX_RESULTS_PER_FETCH=100
# INITIAL_LOOKBACK_MINUTES=5
# LOG_LEVEL=info
# LOG_JSON=true
# SNAPSHOT_DELAYS=15m,30m,45m,60m
# SNAPSHOT_CHECK_INTERVAL_SECONDS=60
# SNAPSHOT_BATCH_SIZE=100
