# Copy to .env — the refresh token lives in macOS Keychain (public client, no secret needed).
# See README or plan for keychain setup commands.
X_CLIENT_ID=YOUR_X_CLIENT_ID
DATABASE_URL=postgres://user:pass@db.xxx.supabase.co:5432/postgres?sslmode=require

# Optional overrides (defaults shown)
# POLL_INTERVAL_SECONDS=300
# MAX_RESULTS_PER_FETCH=100
# INITIAL_LOOKBACK_HOURS=24
# LOG_LEVEL=info
# LOG_JSON=true
